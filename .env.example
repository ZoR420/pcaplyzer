# AI provider: openai or gemini
AI_PROVIDER=openai

OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4

OR

GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-1.5-flash

# Optional cleanup
CLEANUP_UPLOADS=false
UPLOAD_TTL_HOURS=24
TSHARK_MAX_BUFFER_MB=100

# API security
REQUIRE_API_KEY=false
PCAPLYZER_API_KEY=change-me
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=30


1. Sign in to Google AI Studio: Visit Google AI Studio and log in with your Google account.

2. Access the Gemini API Section: Navigate to the "Gemini API" tab or select "Learn More About Gemini API."

3. Obtain the API Key: Click "Get API Key in Google AI Studio," review and accept the terms of service, then choose to create the API key in a new or existing project.

4. Secure Your API Key: After generation, store your API key securely to prevent unauthorized access.

# Environment
NODE_ENV=development

# Debug mode
DEBUG=false
